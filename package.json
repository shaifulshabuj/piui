{
  "name": "piui",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop UI for the pi coding agent",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --port 5616",
    "dev:web": "vite",
    "test": "playwright test",
    "test:unit": "vitest run tests/",
    "test:ui": "playwright test --ui",
    "build": "electron-vite build",
    "build:web": "tsc -b && vite build",
    "build:app": "electron-vite build && electron-builder",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "start": "electron-vite build && electron ."
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "works.earendil.pi",
    "productName": "pi",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "out/**"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
